{% set test_event_date = now(utc=true,fmt='%Y-%m-%dT%H:%M:%SZ') -%}

[[tests]]
  name = "ulp_prepare_ttl: it sets TTL ({{ vector_environment }} env)"

  [[tests.inputs]]
    insert_at = "ulp_prepare_ttl"
    type = "log"

    [tests.inputs.log_fields]
      "PipelineError" = ""
      "Attributes.\"logging.vi.ru/ttl\"" = "{{ ulp.allowed_ttl_days[-1] }}d"
      "Resource.\"env\"" = "{{ vector_environment }}"


  [[tests.outputs]]
    extract_from = "ulp_prepare_ttl"

    [[tests.outputs.conditions]]
      type = "vrl"
      source = '''
        assert_eq!(.Attributes."logging.vi.ru/ttl", "{{ ulp.allowed_ttl_days[-1] }}d")
        assert_eq!(.PipelineError, "")
        assert_eq!(.TTL, {{ ulp.allowed_ttl_days[-1] }})
       '''

[[tests]]
  name = "ulp_prepare_ttl: it sets TTL default if ttl value unsupported ({{ vector_environment }} env)"

  [[tests.inputs]]
    insert_at = "ulp_prepare_ttl"
    type = "log"

    [tests.inputs.log_fields]
      "PipelineError" = ""
      "Attributes.\"logging.vi.ru/ttl\"" = "777d"
      "Resource.\"env\"" = "{{ vector_environment }}"

  [[tests.outputs]]
    extract_from = "ulp_prepare_ttl"

    [[tests.outputs.conditions]]
      type = "vrl"
      source = '''
        assert_eq!(.Attributes."logging.vi.ru/ttl", "777d")
        assert_eq!(.TTL,  {{ ulp.default_ttl_days }})
        assert_eq!(.PipelineError, ", Unsupported log TTL value. Default used")
       '''

