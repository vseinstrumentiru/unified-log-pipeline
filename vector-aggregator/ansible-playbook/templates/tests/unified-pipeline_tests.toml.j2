[[tests]]
  name = "ulp_check_json_route_test"

  [[tests.inputs]]
    insert_at = "all_logs_get_service_name_remap"
    type = "log"

    [tests.inputs.log_fields]
      source_type = "all_logs_get_service_name_remap"
      stream = "stdout"

      "kubernetes.pod_labels.app_name" = "svc_sproduction"
      k8s_service_name = "test::cluster_name"
      "kubernetes.pod_name" = "pcb_svc-7df5b6b4bc-p3w45"
      "kubernetes.pod_labels.\"pod-template-hash\"" = "7df5b6b4bc"
      "kubernetes.pod_ip" = "192.192.192.42"
      "kubernetes.pod_namespace" = "test-app-namespace"
      "kubernetes.container_name" = "test-app-ws"
      "kubernetes.container_image" = "pkg-store/k8s/test-app-ws-image:93dsd2-42"
      "kubernetes.pod_owner" = "some_user"
      "kubernetes.node_labels.beta.\"kubernetes.io/os\"" = "amd64"
      "kubernetes.node_labels.node.\"deckhouse.io/type\"" = "Static"

      # message без закрывающей фигурной скобки
      message = '{ "ts": "{{ test_event_date }}","nginx.request_id": "6a432b1e521b042789c1e984aee21127","user": "","client.address": "192.192.192.236","server.address": "nn.example.org","http.request.body.size": "4799","http.response.body.size": "14720","network.protocol.name": "HTTP/1.1","http.request.method": "GET","http.url": "/brand/makita-1/dreli-2/?activeRegionId=-1&id=26","http.request.header.referer": "https://www.example.org/","user_agent": "Mozilla/5.0 (Windows NT 6.1; Win64; x64; rv:108.0) Gecko/20100101 Firefox/108.0","http.request.duration": "0.3","http.response.status_code": "200","nginx.upstream_addr": "127.0.0.1:4000","nginx.upstream_bytes_received": "14693","upstream_response_time": "0.217","upstream_status": "200" '

  [[tests.outputs]]
    extract_from = "ulp_message_processing"

    [[tests.outputs.conditions]]
      type = "vrl"
      source = '''
        assert!(exists(.ObservedTimestamp) == true)
        assert!(exists(.PipelineError) == true)

        assert_eq!(.PipelineError, "InvalidJson; UnprocessableEntity")

        assert_eq!(.Resource.source_type, "all_logs_get_service_name_remap")
        assert_eq!(.Resource.stream, "stdout")
        assert_eq!(.Resource."kubernetes.pod_labels.app_name", "svc_sproduction")
        assert_eq!(.Resource.k8s_service_name, "test::cluster_name")
        assert_eq!(.Resource."kubernetes.pod_name", "pcb_svc-7df5b6b4bc-p3w45")
        assert_eq!(.Resource."kubernetes.pod_labels.pod-template-hash", "7df5b6b4bc")
        assert_eq!(.Resource."kubernetes.pod_ip", "192.192.192.42")
        assert_eq!(.Resource."kubernetes.pod_namespace", "test-app-namespace")
        assert_eq!(.Resource."kubernetes.container_name", "test-app-ws")
        assert_eq!(.Resource."kubernetes.container_image", "pkg-store/k8s/test-app-ws-image:93dsd2-42")
        assert_eq!(.Resource."kubernetes.pod_owner", "some_user")
        assert_eq!(.Resource."kubernetes.node_labels.beta.kubernetes.io/os", "amd64")
        assert_eq!(.Resource."kubernetes.node_labels.node.deckhouse.io/type", "Static")

        assert_eq!(.Body, "{ \"ts\": \"{{ test_event_date }}\",\"nginx.request_id\": \"6a432b1e521b042789c1e984aee21127\",\"user\": \"\",\"client.address\": \"192.192.192.236\",\"server.address\": \"nn.example.org\",\"http.request.body.size\": \"4799\",\"http.response.body.size\": \"14720\",\"network.protocol.name\": \"HTTP/1.1\",\"http.request.method\": \"GET\",\"http.url\": \"/brand/makita-1/dreli-2/?activeRegionId=-1&id=26\",\"http.request.header.referer\": \"https://www.example.org/\",\"user_agent\": \"Mozilla/5.0 (Windows NT 6.1; Win64; x64; rv:108.0) Gecko/20100101 Firefox/108.0\",\"http.request.duration\": \"0.3\",\"http.response.status_code\": \"200\",\"nginx.upstream_addr\": \"127.0.0.1:4000\",\"nginx.upstream_bytes_received\": \"14693\",\"upstream_response_time\": \"0.217\",\"upstream_status\": \"200\" ")
       '''

