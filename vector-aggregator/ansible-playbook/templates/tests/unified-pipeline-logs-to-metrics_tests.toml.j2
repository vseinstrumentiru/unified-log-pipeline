# Tests: ulp_log_metrics_exclude_filter
#
[[tests]]
  name = "ulp_log_metrics_exclude_filter: it filters out excluded entity with OPTIONS method"
  no_outputs_from = ["ulp_log_metrics_exclude_filter"]

  [[tests.inputs]]
    insert_at = "ulp_log_metrics_exclude_filter"
    type = "log"

    [tests.inputs.log_fields]
      ServiceName = "any"
      "Resource.\"env\"" = "production"
      "Resource.\"k8s_cluster_name\"" = "cl_01"
      "Resource.\"kubernetes.container_name\"" = "nginx"
      "Resource.\"kubernetes.pod_namespace\"" = "any-ns"
      "Attributes.\"http.request.method\"" = "OPTIONS" #
      "Attributes.\"http.response.status_code\"" = "200"
      "Attributes.\"url.host\"" = "anyapp-local"
      "Attributes.\"url.path\"" = "/any"
      "Attributes.\"url.port\"" = "80"
      "Attributes.\"url.query\"" = ""
      "Attributes.\"url.scheme\"" = "http"


