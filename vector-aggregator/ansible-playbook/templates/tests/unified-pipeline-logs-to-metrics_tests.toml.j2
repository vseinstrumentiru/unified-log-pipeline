[[tests]]
  name = "ulp_log_metrics_exclude_filter: it allows not excluded entity"

  [[tests.inputs]]
    insert_at = "ulp_log_metrics_exclude_filter"
    type = "log"

    [tests.inputs.log_fields]
      ServiceName = "testapp"
      "Resource.\"env\"" = "production"
      "Resource.\"k8s_cluster_name\"" = "cl_01"
      "Resource.\"kubernetes.container_name\"" = "nginx"
      "Resource.\"kubernetes.pod_namespace\"" = "testapp-production"
      "Attributes.\"http.request.method\"" = "GET"
      "Attributes.\"http.response.status_code\"" = "200"
      "Attributes.\"url.host\"" = "anyapp-local"
      "Attributes.\"url.path\"" = "/not-excluded-path"
      "Attributes.\"url.port\"" = "80"
      "Attributes.\"url.query\"" = ""
      "Attributes.\"url.scheme\"" = "http"

  [[tests.outputs]]
    extract_from = "ulp_log_metrics_exclude_filter"

    [[tests.outputs.conditions]]
      type = "vrl"
      source = '''
        assert_eq!(.ServiceName, "testapp")
        assert_eq!(.Attributes."url.path", "/not-excluded-path")
      '''


